# payment_gateways — backend companion
# Copy to .env.local for local dev, .env.production for prod.

# ---------- Server ----------
PORT=4000
NODE_ENV=development
LOG_LEVEL=info
API_KEY=replace-with-a-strong-random-string

# ---------- Allowed Origins ----------
# Comma-separated. Used by CORS middleware.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ---------- Stripe ----------
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------- Paymob ----------
# Get these from your Paymob dashboard.
PAYMOB_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYMOB_HMAC_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYMOB_IFRAME_ID=12345
PAYMOB_INTEGRATION_ID_CARD=12345
PAYMOB_INTEGRATION_ID_WALLET=67890

# ---------- PayTabs ----------
PAYTABS_PROFILE_ID=12345
PAYTABS_SERVER_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYTABS_REGION=ARE  # ARE | SAU | KWT | OMN | JOR | EGY | GLOBAL

# ---------- Fawry ----------
FAWRY_MERCHANT_CODE=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FAWRY_SECURITY_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FAWRY_USE_STAGING=true

# ---------- PayPal ----------
PAYPAL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYPAL_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYPAL_USE_SANDBOX=true

# ---------- Square ----------
SQUARE_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SQUARE_APPLICATION_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SQUARE_LOCATION_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SQUARE_USE_SANDBOX=true

# ---------- Storage ----------
# v0.1 uses an in-memory store. v0.5+ supports MongoDB via MONGO_URI.
# MONGO_URI=mongodb://localhost:27017/payment_gateways
